# ── Application ──────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=change-me-to-a-random-secret-key
LOG_LEVEL=INFO

# ── Storage Paths ─────────────────────────────────────────────
INBOX_DIR=storage/inbox
PROCESSED_DIR=storage/processed
FAILED_DIR=storage/failed
LOG_DIR=logs

# ── Database ──────────────────────────────────────────────────
DATABASE_URL=sqlite:///rpa_invoices.db

# ── Reference Data ────────────────────────────────────────────
VENDORS_CSV=sample_data/vendors.csv
PURCHASE_ORDERS_CSV=sample_data/purchase_orders.csv

# ── Validation Rules ──────────────────────────────────────────
AMOUNT_THRESHOLD=10000.00
CONFIDENCE_THRESHOLD=0.75

# ── Email / IMAP (optional) ───────────────────────────────────
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=invoices@yourcompany.com
IMAP_PASSWORD=your-app-password
IMAP_FOLDER=INBOX
IMAP_POLL_INTERVAL_SECONDS=60

# ── Flask Dashboard ───────────────────────────────────────────
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=false

# ── Tesseract (Windows path example) ─────────────────────────
# TESSERACT_CMD=C:/Program Files/Tesseract-OCR/tesseract.exe
